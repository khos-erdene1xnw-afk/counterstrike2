# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Database (Prisma) ----
DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# ---- Steam Web API ----
STEAM_WEB_API_KEY=your-steam-web-api-key

# ---- Steam Trade Bot (dedicated bot account) ----
STEAM_BOT_USERNAME=your-bot-account-name
STEAM_BOT_PASSWORD=your-bot-account-password
STEAM_BOT_SHARED_SECRET=base64-shared-secret-from-maFile
STEAM_BOT_IDENTITY_SECRET=base64-identity-secret-from-maFile

# ---- QPay (Mongolia) ----
QPAY_BASE_URL=https://merchant.qpay.mn/v2
QPAY_USERNAME=your-qpay-merchant-username
QPAY_PASSWORD=your-qpay-merchant-password
QPAY_INVOICE_CODE=your-qpay-invoice-code

# ---- Redis cache (Upstash REST) — optional; falls back to in-memory ----
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ---- Cron protection ----
CRON_SECRET=long-random-string-used-as-bearer-token

# ---- App ----
NEXT_PUBLIC_APP_URL=https://yourdomain.com
COMMISSION_RATE=0.025
DEFAULT_USD_MNT_RATE=3420
